# Default behavior is standalone local demo mode so the GUI works without a backend.
# The local demo engine is browser-side and is NOT a replacement for the original Python ML inference.
VITE_USE_LOCAL_DEMO=true
VITE_FALLBACK_TO_LOCAL_DEMO=true

# Use these values when you create/run a Python API adapter for the original notebook logic.
VITE_API_BASE_URL=http://localhost:8000
VITE_GENERATE_MCQ_ENDPOINT=/api/generate-mcq
VITE_ANSWER_QUESTION_ENDPOINT=/api/answer-question
